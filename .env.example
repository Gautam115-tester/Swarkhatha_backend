# Storage: Drime Cloud
#
# Unlike the old MediaFire setup, Drime needs NO app-wide credentials
# here at all — each pooled storage account is added purely through the
# API (POST /api/storage/accounts) after deploy, using a personal access
# token generated from that Drime account's own dashboard
# (Account Settings -> Developers -> Create a token). Tokens are
# encrypted at rest with TOKEN_ENC_KEY above before being stored — see
# README.md and DEPLOYMENT.md.
#
# Optional: override the Drime API base URL (rarely needed).
# DRIME_API_BASE=https://app.drime.cloud/api/v1

# Optional: how long the short-lived signed URLs behind stream-url /
# download-url stay valid, in seconds (default 900 = 15 minutes).
# STREAM_TOKEN_TTL_SECONDS=900

# Optional: how often (ms) the backend polls each Drime account in the
# background for the live storage dashboard (default 8000).
# STORAGE_REFRESH_INTERVAL_MS=8000
